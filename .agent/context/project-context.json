  "architectural_decisions": [
    {
      "decision_type": "Frontend Design System",
      "rationale": "Adopting Airbnb's visual design language: typography, spacing, color tokens (#E31C5F coral red, #222222 dark, #717171 muted grey), and component patterns",
      "impact_score": 10,
      "files_affected": ["public/assets/front/css/style.css"]
    },
    {
      "decision_type": "Homepage Search Bar",
      "rationale": "Full Airbnb-style search widget with location, date, guest pickers and inline dropdown panels. Z-index stack: header=1000, search-container=1001, dropdowns=1050+",
      "impact_score": 9,
      "files_affected": [
        "resources/views/frontend/home/index.blade.php",
        "public/assets/front/css/style.css"
      ]
    },
    {
      "decision_type": "Lokasi-Dermaga Split View",
      "rationale": "Airbnb-style /lokasi-dermaga page: 55% left panel (scrollable card list) + 45% right panel (sticky Leaflet map). Root cause of previous stacking bug: extra closing </div> that excluded map-panel from flex container.",
      "impact_score": 9,
      "files_affected": [
        "resources/views/frontend/hotel/hotel-map.blade.php",
        "public/assets/front/css/style.css"
      ]
    },
    {
      "decision_type": "Room Details Single Product Page",
      "rationale": "Full Airbnb clone of single product page: sticky detail nav, 5-photo grid gallery, 2-col layout (67% details + 33% sticky booking card), host section, amenities, reviews, location map.",
      "impact_score": 10,
      "files_affected": [
        "resources/views/frontend/room/room-details.blade.php",
        "public/assets/front/css/style.css"
      ]
    },
    {
      "decision_type": "Backend Service Layer",
      "rationale": "RoomService.php created to encapsulate room query logic with proper joins (room_contents -> rooms -> hotels -> hotel_contents -> hotel_categories). categoryName, latitude/longitude available directly on $roomContent.",
      "impact_score": 8,
      "files_affected": [
        "app/Services/RoomService.php",
        "app/Http/Controllers/FrontEnd/RoomController.php"
      ]
    },
    {
      "decision_type": "Hotel Map Controller - Haversine Distance",
      "rationale": "Distance-based filtering using SQL Haversine formula. Fixed undefined variables: $radius, $bs, $locationIds. Used paginate() and simplePaginate() for pagination.",
      "impact_score": 7,
      "files_affected": [
        "app/Http/Controllers/FrontEnd/HotelController.php"
      ]
    }
  ],

