  "known_issues_resolved": [
    {
      "issue": "Split view stacking on /lokasi-dermaga",
      "root_cause": "Extra closing </div> at line 242 of hotel-map.blade.php prematurely closed the split-view-container flex parent before the map-panel div.",
      "fix": "Removed extra </div> so map-panel is a direct child of split-view-container.",
      "status": "RESOLVED"
    },
    {
      "issue": "Z-index chaos on homepage search bar",
      "root_cause": "Multiple elements competing for z-index without a fixed scale. Header, search bar, and dropdown panels were at conflicting layers.",
      "fix": "Established fixed z-index scale: header=1000, search-container=1001, dropdowns=1050+.",
      "status": "RESOLVED"
    },
    {
      "issue": "500 Internal Server Error on /lokasi-dermaga",
      "root_cause": "Undefined variables $radius, $bs, $locationIds in HotelController and unbalanced braces causing ParseError.",
      "fix": "Fixed variable definitions and brace balancing in HotelController.",
      "status": "RESOLVED"
    },
    {
      "issue": "map_debug_1773238434333.png shows empty/tiny map panel",
      "root_cause": "Subagent attempted to inspect map panel before the split view fix was applied.",
      "fix": "Fixed by the split-view div nesting correction.",
      "status": "RESOLVED"
    }
  ],

